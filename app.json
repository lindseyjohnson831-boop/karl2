{
  "expo": {
    "name": "KarlCheck",
    "slug": "KarlCheckApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "bundleIdentifier": "com.ctluck.karlcheck",
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "KarlCheck uses the camera so you can share a photo of current fog conditions in your neighborhood.",
        "NSPhotoLibraryUsageDescription": "KarlCheck lets you upload a photo from your library to share current fog conditions.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.ctluck.karlcheck",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "assetBundlePatterns": [
      "assets/**"
    ],
    "plugins": [
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "832fdb30-093e-4a01-a129-3167f8e72757"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/832fdb30-093e-4a01-a129-3167f8e72757"
    }
  }
}
