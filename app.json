{
  "expo": {
    "name": "KarlCheck",
    "slug": "karlcheck",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#eae8e4"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.karlcheck.app",
      "infoPlist": {
        "NSCameraUsageDescription": "KarlCheck uses your camera to share fog conditions with your neighbors.",
        "NSPhotoLibraryUsageDescription": "KarlCheck uses your photo library to share fog conditions with your neighbors."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#eae8e4"
      },
      "package": "com.karlcheck.app"
    },
    "plugins": [
      "react-native-reanimated",
      "expo-image-picker"
    ]
  }
}
